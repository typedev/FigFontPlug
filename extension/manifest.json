{
  "manifest_version": 3,
  "name": "FigFontPlug",
  "version": "0.1.0",
  "description": "Enables local font access in Figma on Linux",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.figma.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.figma.com/*"],
      "js": ["spoof.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ua_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
